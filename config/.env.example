##############################################################################
# CONFIGURATION ENVIRONNEMENT - TP_SEO
# Copier ce fichier en .env et adapter les valeurs
##############################################################################

# Base de Données PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=tp_seo

# Configuration Application
APP_DEBUG=true
APP_ENV=dev
APP_URL=http://localhost:8001

##############################################################################
# Pour utiliser un port différent:
# 1. Modifier docker-compose.yml - changer "8001:80" par "VOTRE_PORT:80"
# 2. Modifier config/.env - changer "APP_URL=http://localhost:8001"
#    vers "APP_URL=http://localhost:VOTRE_PORT"
#
# Exemple pour le port 3000:
# - docker-compose.yml: ports: - "3000:80"
# - config/.env: APP_URL=http://localhost:3000
##############################################################################
